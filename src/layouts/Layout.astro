---
import TopBar from "../components/TopBar.astro";
import Footer from "../components/Footer.astro";
import "../styles/global.css";
import { SITE_CONFIG } from "../config";

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const { title, description, ogImage } = Astro.props;
const config = SITE_CONFIG;
---

<!doctype html>
<html lang="zh-CN" data-theme="autumn" data-overlayscrollbars-initialize>
  <!-- 默认使用 autumn，由 color-scheme.ts 根据系统偏好自动切换 -->
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <title>{title} - {config.title}</title>
    <meta name="description" content={description || config.subtitle} />

    <meta property="og:site_name" content={config.title} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:url" content={Astro.url.href} />
    {description && <meta property="og:description" content={description} />}
    {ogImage && <meta property="og:image" content={ogImage} />}

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    {description && <meta name="twitter:description" content={description} />}
    {ogImage && <meta name="twitter:image" content={ogImage} />}

    <script is:inline>
      window.walker = {
        colorSchemeSettings: {
          default: "system",
          default_light: "autumn",
          default_dark: "dracula",
          enable_change: true,
          switcher_type: "switch",
          enable_view_transition_api: true,
        },
        activeColorScheme: "system",
      };
    </script>
    <script>
      import { initColorScheme } from "../scripts/color-scheme";
      initColorScheme();
    </script>
    <script>
      import { initAlpine } from "../scripts/init-alpine";
      initAlpine();
    </script>

    <style is:global>
      .main {
        max-width: 1200px;
        margin: 0 auto;
      }
      body {
        font:
          400 18px/1.42 "Droid Serif",
          "PingFang SC",
          "Hiragino Sans GB",
          "Droid Sans Fallback",
          "Microsoft YaHei",
          sans-serif;
        overflow: auto;
      }
    </style>

    <noscript>
      <style>
        body {
          display: block !important;
        }
      </style>
    </noscript>
  </head>
  <body x-data="app" class="hidden" data-overlayscrollbars-initialize>
    <template id="color-scheme-switcher-tpl">
      <label class="switch-type hidden cursor-pointer place-items-center [@supports(color:oklch(0_0_0))]:grid" data-mode="switch">
        <input type="checkbox" class="toggle toggle-md col-span-2 col-start-1 row-start-1 bg-base-content" />
        <svg class="col-start-1 row-start-1 fill-base-100 stroke-base-100" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="5" />
          <path d="M12 1v2M12 21v2M4.2 4.2l1.4 1.4M18.4 18.4l1.4 1.4M1 12h2M21 12h2M4.2 19.8l1.4-1.4M18.4 5.6l1.4-1.4" />
        </svg>
        <svg class="col-start-2 row-start-1 fill-base-100 stroke-base-100" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
        </svg>
      </label>
      <label class="icon-type swap swap-rotate hidden [@supports(color:oklch(0_0_0))]:inline-grid" data-mode="icon">
        <input type="checkbox" />
        <i class="i-tabler-sun swap-on text-base-content/60 hover:text-base-content"></i>
        <i class="i-tabler-moon-stars swap-off text-base-content/60 hover:text-base-content"></i>
      </label>
    </template>
    <TopBar />
    <slot />
    <Footer />

    <button
      type="button"
      id="btn-scroll-to-top"
      class="fixed bottom-5 right-5 flex items-center justify-center rounded-full bg-neutral p-3 opacity-0 shadow transition-all duration-300 hover:opacity-70 hover:shadow-lg lg:bottom-10 lg:right-10"
    >
      <span class="i-tabler-chevron-up text-2xl text-neutral-content"></span>
    </button>
  </body>
</html>

<script>
  import "../scripts/scroll-to-top";
</script>
<script>
  import "../scripts/color-scheme-switcher";
</script>
